# Contract Compass — Example environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# --- Frontend (Vite) ---
# Exposed to the client at build time. The anon key is safe to ship to the browser
# ONLY because Row Level Security is enforced on the database.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Serverless function (Netlify) ---
# Server-side ONLY. Must never be prefixed with VITE_ and must never reach the client.
OPENAI_API_KEY=your-openai-api-key

# Optional: model + API tuning for the analysis function
OPENAI_MODEL=gpt-4o-mini
