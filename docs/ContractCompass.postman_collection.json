{
  "info": {
    "name": "Contract Compass API Tests",
    "description": "Manual API tests for Contract Compass Netlify Function AI endpoints. Supabase auth and CRUD are tested through the app UI and Supabase client; these requests focus on custom serverless endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://contract-compassnj.netlify.app",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "AI Endpoints",
      "item": [
        {
          "name": "Analyze Contract - Success",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"redacted_text\": \"This Agreement shall automatically renew for successive one-year terms unless either party provides written notice of termination at least sixty (60) days prior to the expiration of the then-current term. Payment is due within thirty (30) days of invoice.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/analyze",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "analyze"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('returns risk fields', function () { const json = pm.response.json(); pm.expect(json).to.have.property('summary'); pm.expect(json).to.have.property('risk_level'); pm.expect(json).to.have.property('obligations'); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
